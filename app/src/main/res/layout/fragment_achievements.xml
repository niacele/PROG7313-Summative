<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white"
    tools:context=".Achievements">

    <include
        android:id="@+id/navigationLayout"
        layout="@layout/activity_main" />

    <ImageButton
        android:id="@+id/btnBackButton"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="28dp"
        android:layout_marginTop="92dp"
        android:background="@null"
        android:contentDescription="@string/back_button"
        android:scaleType="fitCenter"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/back_icon_removebg_preview"
        tools:ignore="SpeakableTextPresentCheck" />

    <TextView
        android:id="@+id/txtAchievementsHeading"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Achievements"
        android:textColor="@color/buddydarkblue"
        android:textSize="30sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@+id/btnBackButton"
        app:layout_constraintStart_toEndOf="@+id/btnBackButton"
        android:layout_marginStart="16dp"
        app:layout_constraintTop_toTopOf="@+id/btnBackButton" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="160dp"
        android:layout_marginBottom="90dp"
        android:scrollbars="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:paddingBottom="8dp">

            <!-- Row 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <ImageView
                        android:id="@+id/imgFirstBudget"
                        android:layout_width="120dp"
                        android:layout_height="120dp"
                        android:src="@drawable/achievements_icon_badge"
                        app:tint="#CCCCCC" />

                    <TextView
                        android:id="@+id/txtFirstBudgetTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="My First Budget"
                        android:textColor="@color/buddydarkblue"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:gravity="center" />

                    <TextView
                        android:id="@+id/txtFirstBudgetDesc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Allocate money to an envelope"
                        android:textColor="#93A9A7"
                        android:textSize="12sp"
                        android:gravity="center"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <ImageView
                        android:id="@+id/imgFirstCategory"
                        android:layout_width="120dp"
                        android:layout_height="120dp"
                        android:src="@drawable/achievements_icon_badge"
                        app:tint="#CCCCCC" />

                    <TextView
                        android:id="@+id/txtFirstCategoryTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="My First Category"
                        android:textColor="@color/buddydarkblue"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:gravity="center" />

                    <TextView
                        android:id="@+id/txtFirstCategoryDesc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Create a new category"
                        android:textColor="#93A9A7"
                        android:textSize="12sp"
                        android:gravity="center"
                        android:layout_marginTop="2dp" />
                </LinearLayout>
            </LinearLayout>


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <ImageView
                        android:id="@+id/imgBudgeting101"
                        android:layout_width="120dp"
                        android:layout_height="120dp"
                        android:src="@drawable/achievements_icon_badge"
                        app:tint="#CCCCCC" />

                    <TextView
                        android:id="@+id/txtBudgeting101Title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Budgeting 101"
                        android:textColor="@color/buddydarkblue"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:gravity="center" />

                    <TextView
                        android:id="@+id/txtBudgeting101Desc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Stick to your budgets for 1 month"
                        android:textColor="#93A9A7"
                        android:textSize="12sp"
                        android:gravity="center"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <ImageView
                        android:id="@+id/imgBudgetBuddies"
                        android:layout_width="120dp"
                        android:layout_height="120dp"
                        android:src="@drawable/achievements_icon_badge"
                        app:tint="#CCCCCC" />

                    <TextView
                        android:id="@+id/txtBudgetBuddiesTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Budget Buddies"
                        android:textColor="@color/buddydarkblue"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:gravity="center" />

                    <TextView
                        android:id="@+id/txtBudgetBuddiesDesc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Share Budget Buddy with a friend"
                        android:textColor="#93A9A7"
                        android:textSize="12sp"
                        android:gravity="center"
                        android:layout_marginTop="2dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Row 3 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <ImageView
                        android:id="@+id/imgSavingStreak"
                        android:layout_width="120dp"
                        android:layout_height="120dp"
                        android:src="@drawable/achievements_icon_badge"
                        app:tint="#CCCCCC" />

                    <TextView
                        android:id="@+id/txtSavingStreakTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Saving Streak"
                        android:textColor="@color/buddydarkblue"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:gravity="center" />

                    <TextView
                        android:id="@+id/txtSavingStreakDesc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Save money for 3 months in a row"
                        android:textColor="#93A9A7"
                        android:textSize="12sp"
                        android:gravity="center"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <ImageView
                        android:id="@+id/imgExpenseTracker"
                        android:layout_width="120dp"
                        android:layout_height="120dp"
                        android:src="@drawable/achievements_icon_badge"
                        app:tint="#CCCCCC" />

                    <TextView
                        android:id="@+id/txtExpenseTrackerTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Expense Tracker"
                        android:textColor="@color/buddydarkblue"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:gravity="center" />

                    <TextView
                        android:id="@+id/txtExpenseTrackerDesc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Log 50 expenses"
                        android:textColor="#93A9A7"
                        android:textSize="12sp"
                        android:gravity="center"
                        android:layout_marginTop="2dp" />
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>