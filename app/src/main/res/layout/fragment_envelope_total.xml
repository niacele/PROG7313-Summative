<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white">

    <include
        android:id="@+id/navigationLayout"
        layout="@layout/layout_navigation" />

    <!-- BACK BUTTON - MOVED FURTHER DOWN -->
    <ImageButton
        android:id="@+id/btnBackButton"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="96dp"
        android:background="@null"
        android:contentDescription="@string/back_button"
        android:scaleType="fitCenter"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/back_icon_removebg_preview" />

    <!-- FILTER BUTTON - MOVED FURTHER DOWN -->
    <ImageButton
        android:id="@+id/btnEnvelopeSettings"
        android:layout_width="31dp"
        android:layout_height="31dp"
        android:layout_marginTop="100dp"
        android:layout_marginEnd="16dp"
        android:background="@null"
        android:contentDescription="Envelope Settings"
        android:scaleType="fitCenter"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/filter_icon_removebg_preview" />

    <!-- ENVELOPE TITLE - MOVED FURTHER DOWN -->
    <TextView
        android:id="@+id/txtEnvelopeTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Envelope Name"
        android:textColor="#C57B7B"
        android:textSize="28sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@+id/btnEnvelopeSettings"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/btnEnvelopeSettings" />

    <!-- PROGRESS BAR - ADJUSTED MARGIN -->
    <ProgressBar
        android:id="@+id/progressBudget"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="0dp"
        android:layout_height="24dp"
        android:layout_marginStart="24dp"
        android:layout_marginTop="24dp"
        android:layout_marginEnd="24dp"
        android:max="100"
        android:progress="0"
        android:progressTint="@color/buddydarkblue"
        android:progressBackgroundTint="#E0E0E0"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/txtEnvelopeTitle" />

    <!-- CURRENT SPENT TEXT -->
    <TextView
        android:id="@+id/txtCurrentSpent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="R0.00"
        android:textColor="#C57B7B"
        android:textSize="14sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="@+id/progressBudget"
        app:layout_constraintTop_toBottomOf="@+id/progressBudget" />

    <!-- TOTAL BUDGET LIMIT TEXT -->
    <TextView
        android:id="@+id/txtTotalBudgetLimit"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="R0.00"
        android:textColor="#C57B7B"
        android:textSize="14sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="@+id/progressBudget"
        app:layout_constraintTop_toBottomOf="@+id/progressBudget" />

    <!-- SCROLLVIEW - ADJUSTED TOP MARGIN -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="56dp"
        android:scrollbars="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/txtCurrentSpent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingBottom="16dp">

            <!-- EXPENSES LOG CARD -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@android:color/white"
                app:strokeColor="@color/buddydarkblue"
                app:strokeWidth="1dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:id="@+id/lblExpenseHeading"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Expenses Log:"
                        android:textColor="#C57B7B"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp"/>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvExpensesList"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        tools:listitem="@layout/item_expense_row" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ALLOCATIONS LOG CARD -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="160dp"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@android:color/white"
                app:strokeColor="@color/buddydarkblue"
                app:strokeWidth="1dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:id="@+id/lblAllocationHeading"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Allocations Log:"
                        android:textColor="#C57B7B"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp"/>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvAllocationsList"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        tools:listitem="@layout/item_expense_row" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>